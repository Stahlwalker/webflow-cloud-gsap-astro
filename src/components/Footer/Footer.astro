---
import './Footer.css';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand" aria-label="Webflow × GSAP">
      <img class="footer-brand-wf" src="/brand/logos/Full_Logo_White.svg" alt="Webflow" height="22" />
      <span class="footer-brand-x" aria-hidden="true">×</span>
      <img class="footer-brand-gsap" src="/brand/logos/gsap-wordmark-cream.svg" alt="GSAP" height="18" />
    </div>

    <nav class="footer-nav" aria-label="Footer">
      <a href="https://webflow.com" target="_blank" rel="noreferrer">Webflow</a>
      <a href="https://gsap.com" target="_blank" rel="noreferrer">GSAP</a>
      <a href="https://astro.build" target="_blank" rel="noreferrer">Astro</a>
      <a href="https://codetv.dev" target="_blank" rel="noreferrer">CodeTV</a>
    </nav>

    <p class="footer-meta">{year} · Deployed on Webflow Cloud</p>
  </div>
</footer>
