---
import './Challenge.css';
---

<section id="challenge" class="section challenge">
  <div class="container">
    <div class="challenge-grid">
      <header class="challenge-head">
        <span class="eyebrow">The Brief</span>
        <h2 class="section-title">Build a site that <em>moves</em>.</h2>
      </header>

      <div class="challenge-body">
        <p class="section-lede">
          Spin up an Astro project, pull in GSAP, and ship something that earns a double-take. From
          scroll-driven storytelling to playful micro-interactions to full-on canvas demos — if it runs in a
          browser, it counts. When you're done, hit one button and Webflow Cloud puts it on the internet.
        </p>

        <ul class="challenge-list">
          <li>
            <span class="num">01</span>
            <div>
              <h3>Start from the template</h3>
              <p>Clone the official <code>astro-gsap</code> starter — Astro + every GSAP plugin pre-registered.</p>
            </div>
          </li>
          <li>
            <span class="num">02</span>
            <div>
              <h3>Animate something real</h3>
              <p>One memorable moment beats ten generic fades. Lean into ScrollTrigger, SplitText, Flip, or MotionPath.</p>
            </div>
          </li>
          <li>
            <span class="num">03</span>
            <div>
              <h3>Deploy to Webflow Cloud</h3>
              <p>Click the Deploy button, connect your repo, and submit your live URL through CodeTV.</p>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

<script>
  import './Challenge.js';
</script>
