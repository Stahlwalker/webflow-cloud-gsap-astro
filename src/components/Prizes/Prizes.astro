---
import './Prizes.css';
---

<section id="prizes" class="section prizes">
  <div class="container">
    <header class="prizes-head">
      <span class="eyebrow">The Prizes</span>
      <h2 class="section-title">Three winners. Real loot.</h2>
      <p class="section-lede">
        Top three submissions each take home a GSAP swag pack <em>and</em> the limited-run Webflow keyboard.
      </p>
    </header>

    <figure class="prize-showcase">
      <div class="prize-showcase-stage" aria-hidden="true"></div>
      <img
        class="prize-showcase-img"
        src="/images/webflow_keyboard.webp"
        alt="The Webflow keyboard — going home with all three winners"
        width="900"
        height="540"
        loading="lazy"
        decoding="async"
      />
      <figcaption class="prize-showcase-caption">All three winners take home a Webflow keyboard + GSAP swag.</figcaption>
    </figure>

    <ol class="prizes-grid">
      <li class="prize-card prize-1">
        <div class="prize-rank">
          <span class="rank-num">1</span>
          <span class="rank-label">First place</span>
        </div>
        <div class="prize-body">
          <h3>The Grand Prize</h3>
          <ul class="prize-loot">
            <li><span class="loot-icon">⌨</span>Webflow keyboard</li>
            <li><span class="loot-icon">🎁</span>GSAP swag pack</li>
            <li><span class="loot-icon">📣</span>Feature on the CodeTV show</li>
          </ul>
        </div>
      </li>

      <li class="prize-card prize-2">
        <div class="prize-rank">
          <span class="rank-num">2</span>
          <span class="rank-label">Second place</span>
        </div>
        <div class="prize-body">
          <h3>Runner-up</h3>
          <ul class="prize-loot">
            <li><span class="loot-icon">⌨</span>Webflow keyboard</li>
            <li><span class="loot-icon">🎁</span>GSAP swag pack</li>
          </ul>
        </div>
      </li>

      <li class="prize-card prize-3">
        <div class="prize-rank">
          <span class="rank-num">3</span>
          <span class="rank-label">Third place</span>
        </div>
        <div class="prize-body">
          <h3>Honorable mention</h3>
          <ul class="prize-loot">
            <li><span class="loot-icon">⌨</span>Webflow keyboard</li>
            <li><span class="loot-icon">🎁</span>GSAP swag pack</li>
          </ul>
        </div>
      </li>
    </ol>
  </div>
</section>

<script>
  import './Prizes.js';
</script>
