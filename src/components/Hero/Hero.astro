---
import './Hero.css';
---

<section id="top" class="hero">
  <div class="hero-bg" aria-hidden="true">
    <div class="orb orb-blue"></div>
    <div class="grid"></div>
  </div>

  <div class="container hero-inner">
    <span class="hero-eyebrow">
      <span class="hero-eyebrow-tag">CodeTV</span>
      <span class="hero-eyebrow-text">Featured Challenge</span>
    </span>

    <h1 class="hero-title">
      <span class="line">Animate the Web.</span>
      <span class="line accent">Deploy in One Click.</span>
    </h1>

    <p class="hero-lede">
      Build something delightful with <strong>Webflow</strong> and <strong>GSAP</strong>. Build a site with
      Webflow or deploy an app with <strong>Webflow Cloud</strong>. Either path counts.
    </p>

    <ul class="hero-meta" aria-label="Challenge facts">
      <li><span class="k">Sponsors</span><span class="v">Webflow + GSAP</span></li>
      <li><span class="k">Build with</span><span class="v">Webflow · GSAP · Astro</span></li>
      <li><span class="k">Winners</span><span class="v">3</span></li>
      <li><span class="k">Grand Prize</span><span class="v"><span class="hero-prize-amount" data-target="5000">$0</span> + keyboard + GSAP swag</span></li>
    </ul>
  </div>
</section>

<script>
  import './Hero.js';
</script>
