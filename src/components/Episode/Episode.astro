---
import './Episode.css';
import StatusCallout from '../StatusCallout/StatusCallout.astro';

const videoId = 'p_G66aSHeps';
const videoTitle = 'GSAP × Webflow Challenge: CodeTV episode';

// Sites the three teams in the episode built.
// TODO: replace the placeholder URLs as builds go live.
const teamBuilds = [
  { name: 'Lunar Landing', href: 'https://lunarland.ing/' },
  { name: 'World Cup 2026', href: '#' },
  { name: 'Sell Your Soul', href: '#' },
];
---

<section id="episode" class="section episode">
  <div class="container">
    <header class="episode-head">
      <span class="eyebrow">Watch the Episode</span>
      <h2 class="section-title">See how it's done.</h2>
      <p class="section-lede">
        Stream the full CodeTV episode for the walkthrough, inspiration, and a look at what the judges
        will be watching for. Then go build yours.
      </p>
    </header>

    <div class="episode-grid">
      <div class="episode-side">
        <StatusCallout />

        <aside class="episode-builds" aria-labelledby="episode-builds-label">
          <span id="episode-builds-label" class="episode-builds-label">Episode builds</span>
          <ul class="episode-builds-list">
            {teamBuilds.map((build) => (
              <li>
                <a
                  class={`episode-build${build.href === '#' ? ' is-placeholder' : ''}`}
                  href={build.href}
                  target={build.href === '#' ? undefined : '_blank'}
                  rel={build.href === '#' ? undefined : 'noreferrer'}
                  aria-disabled={build.href === '#' ? 'true' : undefined}
                >
                  <span class="episode-build-name">{build.name}</span>
                  <svg class="episode-build-arrow" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M7 17L17 7M9 7h8v8"/>
                  </svg>
                </a>
              </li>
            ))}
          </ul>
        </aside>
      </div>

      <div class="episode-frame">
        <iframe
          src={`https://www.youtube-nocookie.com/embed/${videoId}?rel=0&modestbranding=1`}
          title={videoTitle}
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </div>
</section>
