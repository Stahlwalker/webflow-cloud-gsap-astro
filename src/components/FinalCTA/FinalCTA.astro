---
import './FinalCTA.css';

const deployUrl =
  'https://webflow.com/dashboard/cloud/deploy?repo=https://github.com/webflow-examples/astro-gsap';
---

<section class="section final-cta">
  <div class="container">
    <div class="final-grid">
      <article class="cta-card cta-gsap">
        <img class="cta-wordmark" src="/brand/logos/gsap-wordmark-green.svg" alt="GSAP" width="160" height="59" />
        <h3>Learn GSAP, free.</h3>
        <p>
          Every plugin — including all the formerly Club GSAP ones — is now free for everyone, including
          commercial use. Dig into the docs, examples, and cheatsheet to find your move.
        </p>
        <div class="cta-actions">
          <a class="btn btn-primary" href="https://gsap.com" target="_blank" rel="noreferrer">
            Explore GSAP
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
          <a class="btn btn-ghost" href="https://gsap.com/cheatsheet/" target="_blank" rel="noreferrer">Cheatsheet</a>
        </div>
      </article>

      <article class="cta-card cta-deploy">
        <img class="cta-wordmark" src="/brand/logos/Full_Logo_Blue_White.svg" alt="Webflow" width="160" height="42" />
        <h3>Ship it in one click.</h3>
        <p>
          Deploy the starter to Webflow Cloud right from this page. We'll fork the repo into your GitHub,
          mount it on a Webflow site, and hand back a live URL.
        </p>
        <div class="cta-actions">
          <a class="deploy-btn" href={deployUrl} target="_blank" rel="noreferrer" aria-label="Deploy to Webflow">
            <img src="https://webflow.com/img/deploy-dark.svg" alt="Deploy to Webflow" width="180" height="40" />
          </a>
          <a class="btn btn-ghost" href="https://github.com/webflow-examples/astro-gsap" target="_blank" rel="noreferrer">View on GitHub</a>
        </div>
      </article>
    </div>
  </div>
</section>

<script>
  import './FinalCTA.js';
</script>
