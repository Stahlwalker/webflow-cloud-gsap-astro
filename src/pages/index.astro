---
import '../styles/global.css';
import Navbar from '../components/Navbar/Navbar.astro';
import Hero from '../components/Hero/Hero.astro';
import Episode from '../components/Episode/Episode.astro';
import Challenge from '../components/Challenge/Challenge.astro';
import Tools from '../components/Tools/Tools.astro';
import Prizes from '../components/Prizes/Prizes.astro';
import Resources from '../components/Resources/Resources.astro';
import FinalCTA from '../components/FinalCTA/FinalCTA.astro';
import Footer from '../components/Footer/Footer.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/brand/logos/Mark_Logo_Blue.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="The Webflow × GSAP challenge from CodeTV. Build with Astro, animate with GSAP, deploy with Webflow Cloud. Submit your app to win swag + a keyboard." />
    <meta property="og:title" content="Webflow × GSAP × CodeTV Challenge" />
    <meta property="og:description" content="The Webflow × GSAP challenge from CodeTV. Build with Astro, animate with GSAP, deploy with Webflow Cloud. Submit your app to win swag + a keyboard." />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og-codetv.png" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Webflow × GSAP × CodeTV Challenge — Animate the Web. Deploy in One Click." />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="/og-codetv.png" />
    <title>Webflow × GSAP × CodeTV Challenge</title>
  </head>
  <body>
    <Navbar />
    <main>
      <Hero />
      <Episode />
      <Challenge />
      <Tools />
      <Prizes />
      <Resources />
      <FinalCTA />
    </main>
    <Footer />
  </body>
</html>
